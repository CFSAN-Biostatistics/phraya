# Global Configuration for Aligner Benchmark
# Source this file in all scripts: source config/global.env

# Data paths
DATA_ROOT="${DATA_ROOT:-$HOME/data-commons/test/benchmarking/alignment}"
PHRAYA_ROOT="${PHRAYA_ROOT:-$HOME/phraya}"
RESULTS_ROOT="${RESULTS_ROOT:-$HOME/phraya/results/benchmark}"

# Normalization parameters (from global.json)
THREADS=8
REPLICATES=3
COVERAGE=30  # Default read coverage, overridden per target if manifest specifies

# Module names (adjust per site)
MODULE_BWA="${MODULE_BWA:-bwa-mem2}"
MODULE_MINIMAP="${MODULE_MINIMAP:-minimap2}"
MODULE_SAMTOOLS="${MODULE_SAMTOOLS:-samtools}"

# Timing command
TIME_CMD="/usr/bin/time"
