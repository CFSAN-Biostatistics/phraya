# Global Configuration for Aligner Benchmark
# Source this file in all scripts: source config/global.env

# Data paths
DATA_ROOT="${DATA_ROOT:-$HOME/data-commons/test/benchmarking/alignment}"
PHRAYA_ROOT="${PHRAYA_ROOT:-$HOME/phraya}"
RESULTS_ROOT="${RESULTS_ROOT:-$HOME/phraya/results/benchmark}"

# Normalization parameters (from global.json)
THREADS=8
REPLICATES=3
COVERAGE=30  # Default read coverage, overridden per target if manifest specifies

# Tool paths (absolute paths — module system unreliable in SLURM jobs on Reedling2)
BWA_BIN="/nfs/software/apps/micromamba/1.5.8/envs/bwa-v0.7.18/bin/bwa"
MINIMAP2_BIN="/nfs/software/apps/micromamba/1.5.8/envs/minimap2-v2.28/bin/minimap2"
SAMTOOLS_BIN="/nfs/software/apps/micromamba/1.5.8/envs/samtools-v1.20/bin/samtools"
BCFTOOLS_BIN="$HOME/phraya/envs/bcftools/bin/bcftools"
PYTHON3_BIN="$HOME/phraya/envs/bench-py/bin/python3"
K8_BIN="/nfs/software/apps/micromamba/1.5.8/envs/minimap2-v2.28/bin/k8"
PAFTOOLS_BIN="/nfs/software/apps/micromamba/1.5.8/envs/minimap2-v2.28/bin/paftools.js"
